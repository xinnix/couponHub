generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 管理端用户模型 (Admin)
// ============================================
model Admin {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  avatar        String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  refreshTokens AdminRefreshToken[]
  roles         AdminRole[]
  stockLogs     StockLog[] // 库存调整日志

  @@index([email])
  @@index([username])
  @@map("admins")
}

// ============================================
// 核销员模型 (Handler)
// ============================================
model Handler {
  id         String   @id @default(cuid())
  name       String // 核销员姓名
  phone      String   @unique // 手机号（用于匹配 User）
  merchantId String // 所属商户 ID
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 关联关系
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  users    User[]   @relation("HandlerUsers") // 多个 User 可能对应同一个 Handler（手机号相同）
  orders   Order[]  // 核销的订单

  @@index([phone])
  @@index([merchantId])
  @@map("handlers")
}

// ============================================
// 小程序用户模型 (User)
// ============================================
model User {
  id           String @id @default(cuid())
  username     String @unique
  email        String? // 可选字段（微信用户不需要）
  passwordHash String

  // 微信相关字段
  openid     String? @unique // 微信用户唯一标识
  unionid    String? @unique // 开放平台标识（可选）
  sessionKey String? // 会话密钥（加密存储）

  phone       String?
  avatar      String?
  nickname    String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 核销员身份关联
  handlerId String? // 关联 Handler 表
  handler   Handler? @relation("HandlerUsers", fields: [handlerId], references: [id], onDelete: SetNull)

  // 关联
  refreshTokens    UserRefreshToken[]
  todos            Todo[]
  orders           Order[]
  merchantHandlers MerchantHandler[]

  @@index([openid])
  @@index([email])
  @@index([username])
  @@index([handlerId])
  @@map("users")
}

// ============================================
// 角色模型 (仅用于 Admin)
// ============================================
model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  level       Int      @default(0)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  permissions RolePermission[]
  admins      AdminRole[]

  @@index([slug])
  @@map("roles")
}

// ============================================
// 权限模型
// ============================================
model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  // 关联
  roles RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

// ============================================
// Admin 角色关联
// ============================================
model AdminRole {
  id         String   @id @default(cuid())
  adminId    String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  // 关联
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, roleId])
  @@index([adminId])
  @@index([roleId])
  @@map("admin_roles")
}

// ============================================
// 角色权限关联
// ============================================
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  // 关联
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================
// Admin 刷新令牌
// ============================================
model AdminRefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  adminId   String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  // 关联
  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([token])
  @@map("admin_refresh_tokens")
}

// ============================================
// User 刷新令牌
// ============================================
model UserRefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  // 关联
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("user_refresh_tokens")
}

// ============================================
// Todo 示例模型 (小程序用户创建)
// ============================================
model Todo {
  id          String    @id @default(cuid())
  title       String
  description String?
  isCompleted Boolean   @default(false)
  priority    Int       @default(1)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 创建者 (小程序用户)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("todos")
}

// ============================================
// 商户类别 (MerchantCategory)
// ============================================
model MerchantCategory {
  id          String @id @default(cuid())
  name        String @unique // 类别名称（唯一）
  slug        String @unique // URL标识符（唯一，如 "restaurant"）
  description String?        // 描述
  icon        String?        // 图标 URL
  sortOrder   Int    @default(0) // 排序权重（数字越大越靠前）
  status      String @default("ACTIVE") // ACTIVE, INACTIVE

  // 创建者和更新者 (Admin)
  createdById String?
  updatedById String?

  // 关联
  merchants        Merchant[]
  couponTemplates  CouponTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([sortOrder])
  @@map("merchant_categories")
}

// ============================================
// 商户模型 (Merchant)
// ============================================
model Merchant {
  id          String  @id @default(cuid())
  name        String
  logo        String?
  categoryId  String  // 商户类别ID
  area        String? // 区域（A区、B区、C区）
  shopNumber  String? // 铺位号（如：01、02、A1等）
  phone       String?
  gallery     Json? // 图片数组
  description String?
  businessHours String? // 营业时间（格式：HH:MM-HH:MM，如 "10:00-22:00"）
  sortOrder   Int     @default(0) // 排序权重（数字越大越靠前）
  status      String  @default("ACTIVE") // ACTIVE, INACTIVE

  // 创建者和更新者 (Admin)
  createdById String?
  updatedById String?

  // 关联
  category         MerchantCategory  @relation(fields: [categoryId], references: [id])
  handlers         Handler[] // 商户的核销员列表
  merchantHandlers MerchantHandler[]
  orders           Order[]
  settlements      Settlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([area])
  @@index([status])
  @@index([createdById])
  @@index([sortOrder])
  @@map("merchants")
}

// ============================================
// 商户核销员 (MerchantHandler)
// ============================================
model MerchantHandler {
  id         String  @id @default(cuid())
  merchantId String
  userId     String // 关联 User 表
  name       String
  phone      String
  isActive   Boolean @default(true)

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([merchantId, userId])
  @@index([merchantId])
  @@index([userId])
  @@map("merchant_handlers")
}

// ============================================
// 新闻资讯 (News)
// ============================================
model News {
  id             String  @id @default(cuid())
  title          String
  bannerUrl      String?
  content        String // 富文本内容

  viewCount Int     @default(0)
  status    String  @default("DRAFT") // DRAFT, PUBLISHED
  isHero    Boolean @default(false) // 是否头图文章（小程序顶部展示）
  isPopup   Boolean @default(false) // 是否为首页弹窗新闻

  // 小程序码相关
  qrcodeUrl        String?   // 小程序码图片 URL
  qrcodeGeneratedAt DateTime? // 生成时间

  // 创建者和更新者 (Admin)
  createdById String?
  updatedById String?

  // 关联优惠券（多对多）
  coupons NewsCouponRelation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([createdById])
  @@index([isHero]) // 添加索引便于查询头图文章
  @@index([isPopup]) // 添加索引便于查询弹窗新闻
  @@index([status, isPopup]) // 复合索引优化小程序端查询
  @@map("news")
}

// ============================================
// 新闻优惠券关联 (NewsCouponRelation)
// ============================================
model NewsCouponRelation {
  id        String   @id @default(cuid())
  newsId    String
  couponId  String
  createdAt DateTime @default(now())

  // 关联关系
  news   News           @relation(fields: [newsId], references: [id], onDelete: Cascade)
  coupon CouponTemplate @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([newsId, couponId]) // 防止重复关联
  @@index([newsId])
  @@index([couponId])
  @@map("news_coupon_relations")
}

// ============================================
// 券模板 (CouponTemplate)
// ============================================
model CouponTemplate {
  id            String   @id @default(cuid())
  title         String
  buyPrice      Decimal  @db.Decimal(10, 2) // 购买价格
  faceValue     Decimal  @db.Decimal(10, 2) // 面值
  settlementAmount Decimal? @db.Decimal(10, 2) // 结算金额（可选，为空时使用面值）
  stock         Int

  // 新增字段：免费领取和领取限制
  claimLimit    Int?     @default(1)    // 每人限领数量（null=无限制，默认1张）
  isFree        Boolean  @default(false) // 是否为免费券（辅助查询字段）

  // 首页展示标记
  featuredOnHome Boolean @default(false) // 是否展示到首页超值优惠列表

  // 排序权重
  sortOrder      Int      @default(0)    // 排序权重（数字越大越靠前）

  categoryId    String?  // 商户类别ID（可选）
  merchantScope Json     // 适用商户 ID 数组

  // 销售期（控制购买时间）
  saleFrom      DateTime              @default(now()) // 销售开始时间
  saleUntil     DateTime              @default(now()) // 销售结束时间

  // 使用期（控制核销时间）
  useFrom       DateTime              @default(now()) // 使用开始时间
  useUntil      DateTime              @default(now()) // 使用结束时间

  // 相对有效期（可选）
  validDays     Int?     // 购买后X天内有效（如果不设置则使用 useUntil）
                                      // expireAt = 有validDays ? min(useUntil, paidAt+validDays) : useUntil

  description   String?
  usageRules    Json? // 使用规则（JSON 结构化存储）
                     // 结构示例：{ stacking: { type, customText }, refund: { type, customText }, usage: { type, customText } }

  status String @default("ACTIVE") // ACTIVE, EXPIRED, DISABLED

  // 小程序码相关
  qrcodeUrl        String?   // 小程序码图片 URL
  qrcodeGeneratedAt DateTime? // 生成时间

  // 创建者和更新者 (Admin)
  createdById String?
  updatedById String?

  // 关联
  category MerchantCategory? @relation(fields: [categoryId], references: [id])
  orders   Order[]
  news     NewsCouponRelation[] // 反向关联：哪些新闻引用了此优惠券
  stockLogs StockLog[] // 库存变更日志

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([saleFrom, saleUntil])    // 销售期索引
  @@index([useFrom, useUntil])      // 使用期索引
  @@index([createdById])
  @@index([isFree])              // 新增索引：便于查询免费券
  @@index([status, isFree])      // 新增复合索引：优化小程序端查询
  @@index([featuredOnHome])      // 新增索引：便于查询首页超值优惠
  @@index([status, featuredOnHome]) // 新增复合索引：优化首页超值优惠查询
  @@index([sortOrder])           // 新增索引：便于排序查询
  @@index([status, sortOrder])   // 新增复合索引：优化排序查询
  @@map("coupon_templates")
}

// ============================================
// 库存变更日志 (StockLog)
// ============================================
model StockLog {
  id           String   @id @default(cuid())
  templateId   String   // 券模板 ID
  changeAmount Int      // 库存变化量（正数=增加，负数=减少）
  currentStock Int      // 变更后的库存数量
  reason       String   // 变更原因：ORDER_CREATE, ORDER_CANCEL, REFUND, EXPIRED_REFUND, MANUAL_ADJUST
  orderId      String?  // 关联订单 ID（可选）
  adminId      String?  // 操作员 ID（手动调整时记录）
  metadata     Json?    // 扩展信息（JSON格式，如订单号、退款单号等）
  createdAt    DateTime @default(now())

  // 关联关系
  template CouponTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order    Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  admin    Admin?         @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([createdAt])
  @@index([reason])
  @@index([templateId, createdAt]) // 复合索引：优化查询某个模板的日志
  @@map("stock_logs")
}

// ============================================
// 订单（核心流转实体）
// ============================================
model Order {
  id      String @id @default(cuid())
  orderNo String @unique // 订单号

  userId     String
  templateId String
  status     String @default("UNPAID") // UNPAID, PAID, REDEEMED, REFUNDING, REFUNDED, EXPIRED, CANCELLED

  // 支付信息
  payId    String?   @unique // 微信支付订单号
  paidAt   DateTime?
  expireAt DateTime? // 订单过期时间（paidAt + validDays天）

  // 核销信息
  redeemMerchantId String?
  handlerId        String? // 核销员 ID
  redeemedAt       DateTime?

  // 退款信息
  refundId     String? // 微信退款单号
  refundReason String?
  refundedAt   DateTime?

  price     Decimal @db.Decimal(10, 2)
  faceValue Decimal @db.Decimal(10, 2)

  // 新增字段：标记免费领取订单
  isFreeOrder Boolean @default(false) // 标记是否为免费领取订单

  // 结算锁定标记
  isLocked Boolean @default(false)

  user     User           @relation(fields: [userId], references: [id])
  template CouponTemplate @relation(fields: [templateId], references: [id])
  merchant Merchant?      @relation(fields: [redeemMerchantId], references: [id])
  handler  Handler?       @relation(fields: [handlerId], references: [id], onDelete: SetNull)
  stockLogs StockLog[]    // 库存变更日志（关联）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([templateId])
  @@index([userId, templateId])   // 新增复合索引：优化领取统计查询
  @@index([status, expireAt])     // 新增复合索引：优化订单过期查询
  @@index([status, createdAt])    // 新增复合索引：优化超时订单查询
  @@index([payId])
  @@index([orderNo])
  @@index([redeemMerchantId])
  @@index([handlerId])
  @@map("orders")
}

// ============================================
// 结算单 (Settlement)
// ============================================
model Settlement {
  id         String @id @default(cuid())
  merchantId String
  period     String // 格式: 2024-03

  totalAmount Decimal @db.Decimal(10, 2)
  orderCount  Int

  status String @default("PENDING") // PENDING, CONFIRMED, PAID

  // 快照数据
  snapshotData Json // 订单快照

  confirmedAt DateTime?
  confirmedBy String?
  paidAt      DateTime?

  merchant Merchant @relation(fields: [merchantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([merchantId, period])
  @@index([status])
  @@index([merchantId])
  @@map("settlements")
}

// ============================================
// 退款失败日志 (RefundFailureLog)
// ============================================
model RefundFailureLog {
  id           String   @id @default(cuid())
  orderId      String
  orderNo      String
  refundNo     String?
  errorMessage String
  retryCount   Int      @default(0)
  status       String   @default("PENDING") // PENDING | RETRYING | SUCCESS | FAILED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("refund_failure_logs")
}
